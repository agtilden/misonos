# Copy to .env and fill in. docker compose reads this automatically.

# LAN IP of THIS docker host that your Sonos speakers can reach.
# NOT the Tailscale 100.x address. Find it with:  ip -4 addr show | grep 192.168
MISONOS_LAN_IP=192.168.68.50

# Optional Phish.in API key (leave blank if you don't have one).
MISONOS_PHISH_API_KEY=
